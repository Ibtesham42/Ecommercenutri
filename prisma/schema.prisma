// Nutriyet — Prisma schema
// All monetary values are stored as INTEGERS in paise (₹1 = 100 paise)
// to avoid floating-point errors and to be Razorpay-ready (Razorpay uses paise).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection used by the app at runtime (good for serverless).
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection used by Prisma Migrate. For Neon this is
  // the same host with "-pooler" removed.
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  USER
  ADMIN // sub-admin: access limited by `permissions`
  SUPER_ADMIN // main admin: full access, manages admins + store settings
}

enum AddressType {
  HOME
  WORK
  OTHER
}

enum CouponType {
  PERCENT
  FIXED
}

enum OrderStatus {
  PENDING
  PAID // legacy (kept for existing rows); fulfilment uses the stages below
  APPROVED
  PROCESSING
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED // future-ready
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  RAZORPAY // online (Razorpay, or the keyless mock)
  COD // cash on delivery — collected at delivery
}

enum StoryMediaType {
  IMAGE
  VIDEO
}

enum AIRole {
  SYSTEM
  USER
  ASSISTANT
}

// ---------------------------------------------------------------------------
// Auth (NextAuth v5 / Auth.js Prisma adapter)
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  phone         String?
  role          Role      @default(USER)
  // For sub-admins (role ADMIN): allowed admin section keys, e.g. ["products","stories"].
  // Ignored for SUPER_ADMIN (full access) and USER.
  permissions   String[]  @default([])
  contactEmail  String? // optional admin contact, distinct from login email
  address       String? // optional admin address
  isActive      Boolean   @default(true) // deactivated admins/users cannot sign in
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  orders   Order[]
  addresses Address[]
  reviews  Review[]
  wishlist WishlistItem[]
  aiChats  AIChat[]
  cart     Cart?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------

model Category {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String?
  image           String?
  parentId        String?
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parent     Category?   @relation("CategoryToSubcategory", fields: [parentId], references: [id])
  children   Category[]  @relation("CategoryToSubcategory")
  products   Product[]
  heroSlides HeroSlide[]
  banners    Banner[]

  @@index([parentId])
}

model Brand {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
}

model Product {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  sku              String?  @unique
  shortDescription String?
  description      String   @db.Text
  benefits         String?  @db.Text
  ingredients      String?  @db.Text
  nutritionFacts   Json? // [{ label, value, unit, perServing? }]
  categoryId       String
  brandId          String?
  isActive         Boolean  @default(true)
  isFeatured       Boolean  @default(false)
  isBestSeller     Boolean  @default(false)
  // Tax & shipping overrides. Null = fall back to the global store defaults
  // (StoreSetting.defaultGstRate / defaultShippingFee). GST is inclusive: the
  // listed price already contains tax at this rate.
  gstRate          Int? // GST percent for this product (e.g. 0,5,12,18,28); null = store default
  deliveryCharge   Int? // paise; per-product delivery override; null = store default, 0 = free
  ratingAvg        Float    @default(0)
  ratingCount      Int      @default(0)
  metaTitle        String?
  metaDescription  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category   Category         @relation(fields: [categoryId], references: [id])
  brand      Brand?           @relation(fields: [brandId], references: [id])
  variants   ProductVariant[]
  images     ProductImage[]
  reviews    Review[]
  wishlist   WishlistItem[]
  orderItems OrderItem[]
  stories    Story[]
  aiChats    AIChat[]
  heroSlides HeroSlide[]
  banners    Banner[]

  @@index([categoryId])
  @@index([brandId])
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  weightLabel   String // e.g. "100g", "250g", "500g", "1kg"
  weightInGrams Int? // for sorting / filtering
  price         Int // paise (MRP)
  discountPrice Int? // paise (sale price, <= price)
  stock         Int      @default(0)
  sku           String?  @unique
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Review {
  id         String   @id @default(cuid())
  productId  String
  userId     String
  rating     Int // 1..5
  title      String?
  comment    String?  @db.Text
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId])
}

// ---------------------------------------------------------------------------
// Customer data
// ---------------------------------------------------------------------------

model Address {
  id        String      @id @default(cuid())
  userId    String
  fullName  String
  phone     String
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  country   String      @default("India")
  type      AddressType @default(HOME)
  isDefault Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id            String   @id @default(cuid())
  cartId        String
  variantId     String
  quantity      Int      @default(1)
  savedForLater Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
  @@index([cartId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Commerce
// ---------------------------------------------------------------------------

model Coupon {
  id           String     @id @default(cuid())
  code         String     @unique
  description  String?
  type         CouponType
  value        Int // PERCENT: 1-100, FIXED: paise
  minOrder     Int? // paise
  maxDiscount  Int? // paise (cap for percentage coupons)
  usageLimit   Int? // total redemptions allowed
  usedCount    Int        @default(0)
  perUserLimit Int?
  startsAt     DateTime?
  expiresAt    DateTime?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  orders Order[]
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  userId          String
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(RAZORPAY)
  subtotal        Int // paise
  discount        Int           @default(0)
  shipping        Int           @default(0)
  shippingSaved   Int           @default(0) // paise waived by free-delivery (for "you saved" copy)
  codFee          Int           @default(0) // paise, COD handling fee (0 for online)
  tax             Int           @default(0)
  total           Int // paise
  // True once stock has been decremented for this order (at PAID for online, at
  // confirmation for COD). Drives confirm-idempotency and restock-on-cancel.
  stockDeducted   Boolean       @default(false)
  cancelReason    String? // why the order was cancelled (shown in the timeline)
  couponId        String?
  couponCode      String?
  addressId       String?
  shippingAddress Json // snapshot of the address at purchase time

  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User        @relation(fields: [userId], references: [id])
  coupon  Coupon?     @relation(fields: [couponId], references: [id])
  address Address?    @relation(fields: [addressId], references: [id])
  items   OrderItem[]
  invoice Invoice?
  events  OrderEvent[]

  @@index([userId])
  @@index([status])
}

// Append-only status timeline for an order (one row per transition). Powers the
// customer order tracker with timestamps and the cancellation reason.
model OrderEvent {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String? // e.g. cancellation reason
  actor     String? // "customer" | "admin" | "system"
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  productId    String?
  variantId    String?
  productName  String // snapshot
  variantLabel String // snapshot
  image        String? // snapshot
  price        Int // paise, snapshot of unit price paid
  quantity     Int

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

// One persistent tax invoice per order (created at order confirmation, or lazily
// on first view for legacy orders). The PDF is rendered on demand from the
// immutable order + this seller snapshot, so it never changes once issued.
// `seq` is a DB autoincrement → `invoiceNumber` (INV-<FY>-<seq>) is collision-free.
model Invoice {
  id            String   @id @default(cuid())
  orderId       String   @unique
  seq           Int      @unique @default(autoincrement())
  invoiceNumber String   @unique
  issuedAt      DateTime @default(now())
  // Seller details snapshot at issue time (so later store edits don't rewrite history).
  sellerName    String
  sellerAddress String?
  sellerGstin   String?
  sellerEmail   String?
  sellerPhone   String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Homepage hero slider (CMS-managed)
// ---------------------------------------------------------------------------

model HeroSlide {
  id           String    @id @default(cuid())
  title        String?
  subtitle     String?
  description  String?   @db.Text
  desktopImage String
  mobileImage  String? // falls back to desktopImage when blank
  ctaText      String?
  ctaUrl       String? // explicit link; product/category below take precedence if set
  productId    String?
  categoryId   String?
  overlay      Int       @default(40) // dark overlay opacity, 0-100
  buttonColor  String? // optional CTA background (hex); defaults to brand
  textAlign    String    @default("left") // left | center | right
  sortOrder    Int       @default(0)
  isActive     Boolean   @default(true)
  startsAt     DateTime?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  product  Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([isActive])
}

// Promotional banners rendered at named placements (see lib/banners.ts).
model Banner {
  id           String    @id @default(cuid())
  title        String?
  subtitle     String?
  description  String?   @db.Text
  desktopImage String
  mobileImage  String?
  // Optional dark-mode variants; the light image is used as a fallback.
  desktopImageDark String?
  mobileImageDark  String?
  ctaText      String?
  ctaUrl       String?
  productId    String?
  categoryId   String?
  position     String    @default("homeTop")
  priority     Int       @default(0) // higher shows first within a position
  isActive     Boolean   @default(true)
  startsAt     DateTime?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  product  Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([position, isActive])
}

// Homepage section visibility + order (Homepage Section Builder). One row per
// section key (see lib/home-sections.ts). Missing keys fall back to defaults.
model HomeSection {
  id        String   @id @default(cuid())
  key       String   @unique
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  // Per-section editable content (Homepage Section editor). Null = code defaults
  // in lib/home-content.ts, so the homepage is unchanged until an admin edits.
  content   Json?
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Content / CMS (blog, legal pages, contact inbox)
// ---------------------------------------------------------------------------

// Blog articles. CMS-ready: a future admin phase manages these rows; the
// storefront renders only published posts (see lib/queries/blog.ts).
model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?
  content     String    @db.Text
  coverImage  String?
  author      String?
  tag         String?
  isPublished Boolean   @default(true)
  publishedAt DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isPublished, publishedAt])
}

// Editable legal/policy pages (privacy, terms, shipping). The slug is the page
// key; when a row is absent the storefront falls back to the defaults in
// lib/legal-content.ts. `body` is sanitized HTML rendered on the page.
model ContentPage {
  slug      String   @id // "privacy" | "terms" | "shipping"
  title     String
  body      String   @db.Text
  updatedAt DateTime @updatedAt
}

// Contact-form submissions (the admin inbox). Persisted so messages survive
// even when email delivery isn't configured.
enum ContactStatus {
  NEW
  IN_PROGRESS
  REPLIED
  CLOSED
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String        @db.Text
  handled   Boolean       @default(false) // legacy; status is authoritative
  status    ContactStatus @default(NEW)
  createdAt DateTime      @default(now())

  replies ContactReply[]

  @@index([createdAt])
  @@index([status])
}

// One admin reply in a contact conversation (full support history). Records the
// sender admin, the body, and the email delivery outcome.
model ContactReply {
  id        String   @id @default(cuid())
  messageId String
  body      String   @db.Text
  adminId   String?
  adminName String?
  delivered Boolean  @default(false)
  error     String?
  createdAt DateTime @default(now())

  message ContactMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

// ---------------------------------------------------------------------------
// Instagram-style stories
// ---------------------------------------------------------------------------

model Story {
  id          String         @id @default(cuid())
  title       String
  coverImage  String
  mediaUrl    String
  mediaType   StoryMediaType @default(IMAGE)
  productId   String?
  ctaText     String? // e.g. "Shop now"
  isPublished Boolean        @default(false)
  sortOrder   Int            @default(0)
  viewCount   Int            @default(0)
  expiresAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  product Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  views   StoryView[]

  @@index([isPublished])
}

model StoryView {
  id       String   @id @default(cuid())
  storyId  String
  userId   String?
  anonId   String?
  viewedAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
}

// ---------------------------------------------------------------------------
// AI (Groq)
// ---------------------------------------------------------------------------

model AIChat {
  id        String   @id @default(cuid())
  userId    String?
  productId String?
  sessionId String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  product  Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  messages AIMessage[]

  @@index([userId])
  @@index([sessionId])
}

model AIMessage {
  id        String   @id @default(cuid())
  chatId    String
  role      AIRole
  content   String   @db.Text
  createdAt DateTime @default(now())

  chat AIChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
}

// Single-row, editable store details (branding, contact, socials, SEO). Read
// with a fallback to `config/site.ts`, so the storefront works before any
// values are set. Managed from /admin/appearance.
model StoreSetting {
  id           String   @id @default("singleton")
  // Branding
  siteName     String?
  tagline      String?
  logo         String? // light logo image URL
  logoDark     String? // optional dark-mode logo
  favicon      String?
  // Logo display size (storefront header/footer), px
  logoHeight       Int? // height on desktop
  logoHeightMobile Int? // height on mobile
  logoMaxWidth     Int? // max width
  // Theme
  primaryColor   String? // hex override for --primary
  secondaryColor String? // hex override for --secondary
  // Announcement bar
  announcement       String? // banner text
  announcementActive Boolean @default(false)
  announcementLink   String?
  // Pricing & tax defaults (used when a product doesn't override). GST is
  // inclusive of the listed price. Money is paise.
  defaultGstRate        Int     @default(0)     // GST percent applied by default
  defaultShippingFee    Int     @default(4900)  // paise, standard/default fee below the free threshold
  freeShippingThreshold Int     @default(49900) // paise, subtotal at/above ships free
  freeShippingEnabled   Boolean @default(true)  // master switch for the free-delivery rule
  localDeliveryFee      Int?    // paise, configurable delivery option (managed in /admin/shipping)
  expressDeliveryFee    Int?    // paise, configurable delivery option
  // Cash on Delivery
  codFee                Int?     // paise, COD handling fee
  codEnabled            Boolean  @default(false) // offer COD at checkout
  codMinOrder           Int?     // paise, min subtotal for COD (null = no minimum)
  codMaxOrder           Int?     // paise, max subtotal for COD (null = no maximum)
  codPincodes           String[] @default([]) // future-ready pincode allowlist (empty = all)
  gstin                 String? // seller GSTIN shown on the tax invoice
  // Contact
  supportEmail String?
  supportPhone String?
  whatsapp     String? // digits for wa.me link
  address      String?
  businessHours String?
  mapsEmbedUrl String? // Google Maps embed src
  // Social
  instagram String?
  facebook  String?
  twitter   String?
  youtube   String?
  // SEO defaults
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  updatedAt       DateTime @updatedAt
}

// Single-row settings table. The Groq API key itself is NEVER stored here —
// it lives only in the GROQ_API_KEY environment variable.
model AISetting {
  id                      String   @id @default("singleton")
  model                   String   @default("llama-3.3-70b-versatile")
  isEnabled               Boolean  @default(true)
  assistantEnabled        Boolean  @default(true)
  searchEnabled           Boolean  @default(true)
  productAssistantEnabled Boolean  @default(true)
  systemPrompt            String?  @db.Text
  temperature             Float    @default(0.7)
  maxTokens               Int      @default(1024)
  totalRequests           Int      @default(0)
  totalTokens             Int      @default(0)
  updatedAt               DateTime @updatedAt
}
