generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  phone         String?         @unique
  phoneVerified DateTime?
  gender        Gender?
  dob           DateTime?
  role          Role            @default(USER)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  address       String?
  contactEmail  String?
  isActive      Boolean         @default(true)
  permissions   String[]        @default([])
  recentSearches String[]       @default([]) // newest-first, capped at 8 (search overlay)
  aiChats       AIChat[]
  accounts      Account[]
  addresses     Address[]
  affiliate     Affiliate?
  cart          Cart?
  notifications Notification[]
  orders        Order[]
  pushSubs      PushSubscription[]
  returns       ReturnRequest[]
  reviews       Review[]
  sessions      Session[]
  wishlist      WishlistItem[]
  healthQuizzes HealthQuizResult[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model Category {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  description     String?
  image           String?
  parentId        String?
  sortOrder       Int              @default(0)
  isActive        Boolean          @default(true)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  returnable      Boolean          @default(true)
  banners         Banner[]
  parent          Category?        @relation("CategoryToSubcategory", fields: [parentId], references: [id])
  children        Category[]       @relation("CategoryToSubcategory")
  commissionRules CommissionRule[]
  heroSlides      HeroSlide[]
  products        Product[]

  @@index([parentId])
}

model Brand {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  logo        String?
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  sku              String?          @unique
  shortDescription String?
  description      String
  benefits         String?
  ingredients      String?
  nutritionFacts   Json?
  categoryId       String
  brandId          String?
  isActive         Boolean          @default(true)
  isFeatured       Boolean          @default(false)
  isBestSeller     Boolean          @default(false)
  ratingAvg        Float            @default(0)
  ratingCount      Int              @default(0)
  metaTitle        String?
  metaDescription  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deliveryCharge   Int?
  gstRate          Int?
  returnWindowDays Int?
  returnable       Boolean          @default(true)
  aiChats          AIChat[]
  banners          Banner[]
  commissionRules  CommissionRule[]
  heroSlides       HeroSlide[]
  orderItems       OrderItem[]
  brand            Brand?           @relation(fields: [brandId], references: [id])
  category         Category         @relation(fields: [categoryId], references: [id])
  images           ProductImage[]
  variants         ProductVariant[]
  reviews          Review[]
  showcaseItems    ShowcaseItem[]
  stories          Story[]
  wishlist         WishlistItem[]

  @@index([categoryId])
  @@index([brandId])
}

model ProductVariant {
  id            String      @id @default(cuid())
  productId     String
  weightLabel   String
  weightInGrams Int?
  price         Int
  discountPrice Int?
  stock         Int         @default(0)
  sku           String?     @unique
  isDefault     Boolean     @default(false)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  cartItems     CartItem[]
  orderItems    OrderItem[]
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Review {
  id         String   @id @default(cuid())
  productId  String
  userId     String
  rating     Int
  title      String?
  comment    String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId])
}

model Address {
  id        String      @id @default(cuid())
  userId    String
  fullName  String
  phone     String
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  country   String      @default("India")
  type      AddressType @default(HOME)
  isDefault Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@index([userId])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id            String         @id @default(cuid())
  cartId        String
  variantId     String
  quantity      Int            @default(1)
  savedForLater Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  cart          Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
  @@index([cartId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model Coupon {
  id           String     @id @default(cuid())
  code         String     @unique
  description  String?
  type         CouponType
  value        Int
  minOrder     Int?
  maxDiscount  Int?
  usageLimit   Int?
  usedCount    Int        @default(0)
  perUserLimit Int?
  startsAt     DateTime?
  expiresAt    DateTime?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  categoryIds  String[]   @default([])
  productIds   String[]   @default([])
  affiliate    Affiliate?
  orders       Order[]
}

model Order {
  id                String          @id @default(cuid())
  orderNumber       String          @unique
  userId            String
  status            OrderStatus     @default(PENDING)
  paymentStatus     PaymentStatus   @default(PENDING)
  subtotal          Int
  discount          Int             @default(0)
  shipping          Int             @default(0)
  tax               Int             @default(0)
  total             Int
  couponId          String?
  couponCode        String?
  addressId         String?
  shippingAddress   Json
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  shippingSaved     Int             @default(0)
  codFee            Int             @default(0)
  paymentMethod     PaymentMethod   @default(RAZORPAY)
  stockDeducted     Boolean         @default(false)
  cancelReason      String?
  affiliateId       String?
  referralCode      String?
  commission        Commission?
  invoice           Invoice?
  address           Address?        @relation(fields: [addressId], references: [id])
  affiliate         Affiliate?      @relation(fields: [affiliateId], references: [id])
  coupon            Coupon?         @relation(fields: [couponId], references: [id])
  user              User            @relation(fields: [userId], references: [id])
  events            OrderEvent[]
  items             OrderItem[]
  returns           ReturnRequest[]

  @@index([userId])
  @@index([status])
  @@index([affiliateId])
}

model OrderEvent {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  actor     String?
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model OrderItem {
  id           String              @id @default(cuid())
  orderId      String
  productId    String?
  variantId    String?
  productName  String
  variantLabel String
  image        String?
  price        Int
  quantity     Int
  order        Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product?            @relation(fields: [productId], references: [id])
  variant      ProductVariant?     @relation(fields: [variantId], references: [id])
  returnItems  ReturnRequestItem[]

  @@index([orderId])
}

model Invoice {
  id            String   @id @default(cuid())
  orderId       String   @unique
  seq           Int      @unique @default(autoincrement())
  invoiceNumber String   @unique
  issuedAt      DateTime @default(now())
  sellerName    String
  sellerAddress String?
  sellerGstin   String?
  sellerEmail   String?
  sellerPhone   String?
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ReturnRequest {
  id                String              @id @default(cuid())
  returnNumber      String              @unique
  orderId           String
  userId            String
  status            ReturnStatus        @default(REQUESTED)
  type              ReturnType          @default(REFUND)
  reason            String
  description       String?
  media             String[]            @default([])
  refundAmount      Int                 @default(0)
  refundedAmount    Int                 @default(0)
  refundMethod      RefundMethod?
  refundStatus      RefundStatus        @default(PENDING)
  refundRef         String?
  pickupScheduledAt DateTime?
  pickupNote        String?
  adminNotes        String?
  rejectionReason   String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  creditNote        CreditNote?
  events            ReturnEvent[]
  order             Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user              User                @relation(fields: [userId], references: [id])
  items             ReturnRequestItem[]

  @@index([userId])
  @@index([orderId])
  @@index([status])
}

model ReturnRequestItem {
  id            String        @id @default(cuid())
  returnId      String
  orderItemId   String
  quantity      Int
  unitPrice     Int
  productName   String
  variantLabel  String
  image         String?
  orderItem     OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  returnRequest ReturnRequest @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
}

model ReturnEvent {
  id            String        @id @default(cuid())
  returnId      String
  status        ReturnStatus
  note          String?
  actor         String?
  createdAt     DateTime      @default(now())
  returnRequest ReturnRequest @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
}

model CreditNote {
  id              String        @id @default(cuid())
  returnRequestId String        @unique
  seq             Int           @unique @default(autoincrement())
  number          String        @unique
  issuedAt        DateTime      @default(now())
  amount          Int
  sellerName      String
  sellerAddress   String?
  sellerGstin     String?
  sellerEmail     String?
  sellerPhone     String?
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(GENERAL)
  title     String
  body      String?
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model Affiliate {
  id              String           @id @default(cuid())
  userId          String           @unique
  role            AffiliateRole    @default(AFFILIATE)
  status          AffiliateStatus  @default(PENDING)
  code            String           @unique
  couponId        String?          @unique
  commissionType  CommissionType?
  commissionValue Int?
  displayName     String
  bio             String?
  website         String?
  socials         Json?
  audienceSize    Int?
  pitch           String?
  payoutMethod    PayoutMethod?
  upiId           String?
  bankName        String?
  bankAccount     String?
  bankIfsc        String?
  accountName     String?
  rejectionReason String?
  suspendReason   String?
  approvedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  coupon          Coupon?          @relation(fields: [couponId], references: [id])
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  clicks          AffiliateClick[]
  commissions     Commission[]
  orders          Order[]
  payouts         Payout[]

  @@index([status])
  @@index([role])
}

model AffiliateClick {
  id          String    @id @default(cuid())
  affiliateId String
  anonId      String?
  userId      String?
  landingPath String
  referrer    String?
  device      String?
  browser     String?
  ipHash      String?
  createdAt   DateTime  @default(now())
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([affiliateId, anonId])
}

model CommissionRule {
  id         String          @id @default(cuid())
  scope      CommissionScope
  role       AffiliateRole?
  productId  String?
  categoryId String?
  type       CommissionType  @default(PERCENT)
  value      Int
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  category   Category?       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  product    Product?        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([scope, role, productId, categoryId])
  @@index([scope])
}

model Commission {
  id          String           @id @default(cuid())
  affiliateId String
  orderId     String           @unique
  userId      String
  base        Int
  amount      Int
  status      CommissionStatus @default(PENDING)
  matureAt    DateTime?
  paidAt      DateTime?
  payoutId    String?
  meta        Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  affiliate   Affiliate        @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  order       Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payout      Payout?          @relation(fields: [payoutId], references: [id])

  @@index([affiliateId])
  @@index([status])
}

model Payout {
  id           String        @id @default(cuid())
  payoutNumber String        @unique
  affiliateId  String
  amount       Int
  status       PayoutStatus  @default(REQUESTED)
  method       PayoutMethod?
  reference    String?
  notes        String?
  periodStart  DateTime?
  periodEnd    DateTime?
  paidAt       DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  commissions  Commission[]
  affiliate    Affiliate     @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([status])
}

model MarketingAsset {
  id           String             @id @default(cuid())
  title        String
  description  String?
  type         MarketingAssetType
  fileUrl      String
  thumbnailUrl String?
  fileType     String?
  sizeBytes    Int?
  sortOrder    Int                @default(0)
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([isActive])
}

model HeroSlide {
  id           String    @id @default(cuid())
  title        String?
  subtitle     String?
  description  String?
  mediaType    String    @default("IMAGE") // "IMAGE" | "VIDEO"
  videoUrl     String?
  videoPoster  String? // admin-chosen poster (thumbnail pick or custom upload); null = auto first frame
  videoQuality String    @default("balanced") // delivery profile: "max" | "balanced" | "eco"
  videoMeta    Json? // upload metadata: width/height/duration/bytes/format/codec/fps/bitrate
  desktopImage String
  mobileImage  String?
  ctaText      String?
  ctaUrl       String?
  productId    String?
  categoryId   String?
  overlay      Int       @default(40)
  buttonColor  String?
  textAlign    String    @default("left")
  sortOrder    Int       @default(0)
  isActive     Boolean   @default(true)
  startsAt     DateTime?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  category     Category? @relation(fields: [categoryId], references: [id])
  product      Product?  @relation(fields: [productId], references: [id])

  @@index([isActive])
}

model ShowcaseItem {
  id             String   @id @default(cuid())
  title          String
  tagline        String?
  image          String
  imagePng       String?
  productId      String?
  ctaText        String?
  ctaUrl         String?
  animation      String   @default("float")
  background     String   @default("aurora")
  rotationSpeed  Int      @default(50)
  floatIntensity Int      @default(50)
  zoom           Int      @default(50)
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  product        Product? @relation(fields: [productId], references: [id])

  @@index([isActive])
}

model Banner {
  id               String    @id @default(cuid())
  title            String?
  subtitle         String?
  description      String?
  mediaType        String    @default("IMAGE") // "IMAGE" | "VIDEO"
  videoUrl         String?
  desktopImage     String
  mobileImage      String?
  ctaText          String?
  ctaUrl           String?
  productId        String?
  categoryId       String?
  position         String    @default("homeTop")
  priority         Int       @default(0)
  isActive         Boolean   @default(true)
  startsAt         DateTime?
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  desktopImageDark String?
  mobileImageDark  String?
  category         Category? @relation(fields: [categoryId], references: [id])
  product          Product?  @relation(fields: [productId], references: [id])

  @@index([position, isActive])
}

model HomeSection {
  id        String   @id @default(cuid())
  key       String   @unique
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt
  content   Json?
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String?
  content     String
  coverImage  String?
  author      String?
  tag         String?
  isPublished Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, publishedAt])
}

model ContentPage {
  slug      String   @id
  title     String
  body      String
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String         @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  handled   Boolean        @default(false)
  createdAt DateTime       @default(now())
  status    ContactStatus  @default(NEW)
  replies   ContactReply[]

  @@index([createdAt])
  @@index([status])
}

model ContactReply {
  id        String         @id @default(cuid())
  messageId String
  body      String
  adminId   String?
  adminName String?
  delivered Boolean        @default(false)
  error     String?
  createdAt DateTime       @default(now())
  message   ContactMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model B2BInquiry {
  id           String    @id @default(cuid())
  fullName     String
  companyName  String?
  businessType String
  phone        String
  email        String
  city         String?
  state        String?
  country      String?
  purpose      String
  message      String
  status       B2BStatus @default(NEW)
  adminNotes   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([businessType])
  @@index([createdAt])
}

model Story {
  id          String         @id @default(cuid())
  title       String
  coverImage  String
  mediaUrl    String
  mediaType   StoryMediaType @default(IMAGE)
  productId   String?
  ctaText     String?
  isPublished Boolean        @default(false)
  sortOrder   Int            @default(0)
  viewCount   Int            @default(0)
  expiresAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  product     Product?       @relation(fields: [productId], references: [id])
  views       StoryView[]

  @@index([isPublished])
}

model StoryView {
  id       String   @id @default(cuid())
  storyId  String
  userId   String?
  anonId   String?
  viewedAt DateTime @default(now())
  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
}

// Grows unbounded (no pruning yet) — a retention/rollup job (e.g. delete > 180d)
// is a future follow-up once analytics volume warrants it.
model UserEvent {
  id         String        @id @default(cuid())
  type       UserEventType
  userId     String?
  anonId     String?
  productId  String?
  categoryId String?
  query      String?
  source     String?
  device     String? // "mobile" | "tablet" | "desktop" — derived server-side from the UA header
  referrer   String? // external referrer hostname only (PAGE_VIEW), lowercase, no PII
  path       String? // pathname only (no query string) — journey stages + rage-click location
  city       String? // coarse request geo from the platform header (title-cased; no IP stored)
  region     String? // state/region, same source as city
  createdAt  DateTime      @default(now())

  @@index([type, createdAt])
  @@index([productId, type])
  @@index([userId, createdAt])
  @@index([categoryId, createdAt])
  @@index([createdAt])
}

// Pre-aggregated engagement counters (website heatmap): one row per
// day × page group × section × device, written by /api/heat as increment
// upserts — storage stays tiny no matter the traffic (no per-interaction rows).
model HeatStat {
  id        String   @id @default(cuid())
  day       DateTime @db.Date
  page      String // page group: home | product | category | search | cart | checkout | other
  section   String // data-heat key, or "__page" for page-level scroll/time rollups
  device    String // mobile | tablet | desktop
  views     Int      @default(0) // section-visible impressions
  clicks    Int      @default(0)
  hovers    Int      @default(0) // desktop hover-dwells (≥600ms)
  timeMs    Int      @default(0) // accumulated visible time (capped per beacon)
  scroll25  Int      @default(0) // page-level scroll-depth milestones ("__page" rows)
  scroll50  Int      @default(0)
  scroll75  Int      @default(0)
  scroll100 Int      @default(0)

  @@unique([day, page, section, device])
  @@index([day])
}

// Anonymized session replay: normalized pointer/scroll/nav samples ONLY — no
// DOM capture, no text, no keystrokes, so passwords/payment/PII can never be
// recorded. Client-sampled; pruned by retention on admin reads.
model SessionRecording {
  id              String   @id // client-generated token (validated shape), unguessable
  userId          String?
  anonId          String?
  device          String?
  startedAt       DateTime @default(now())
  endedAt         DateTime @default(now())
  duration        Int      @default(0) // ms across recorded pages
  pages           Json // [{ path, t, w, h, ev: [[dt,kind,x,y|depth], ...] }]
  pageCount       Int      @default(0)
  clickCount      Int      @default(0)
  rageCount       Int      @default(0)
  reachedCheckout Boolean  @default(false)
  purchased       Boolean  @default(false) // saw /checkout/success during the session
  sizeBytes       Int      @default(0)

  @@index([startedAt])
}

model AIChat {
  id        String      @id @default(cuid())
  userId    String?
  productId String?
  sessionId String
  title     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  product   Product?    @relation(fields: [productId], references: [id])
  user      User?       @relation(fields: [userId], references: [id])
  messages  AIMessage[]

  @@index([userId])
  @@index([sessionId])
}

model AIMessage {
  id        String   @id @default(cuid())
  chatId    String
  role      AIRole
  content   String
  createdAt DateTime @default(now())
  chat      AIChat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
}

