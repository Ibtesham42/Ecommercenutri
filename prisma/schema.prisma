// --- Marketing Hub ------------------------------------------------------------

enum CampaignType {
  BROADCAST
  PRODUCT
  COUPON
  AUTOMATION
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
  CANCELLED
}

enum CampaignChannel {
  IN_APP
  EMAIL
  PUSH
  WHATSAPP
  SMS
}

enum SegmentType {
  ALL_USERS
  CUSTOMERS
  AFFILIATES
  PRODUCT_BUYERS
  CATEGORY_BUYERS
  WISHLIST
  ABANDONED_CART
  INACTIVE
  SELECTED
}

model Campaign {
  id              String            @id @default(cuid())
  name            String
  type            CampaignType      @default(BROADCAST)
  status          CampaignStatus    @default(DRAFT)
  channels        CampaignChannel[] @default([IN_APP])
  // content
  title           String
  body            String
  imageUrl        String?
  ctaText         String?
  ctaUrl          String?
  // targeting (segmentConfig: { productId, categoryId, userIds[], inactiveDays })
  segmentType     SegmentType       @default(ALL_USERS)
  segmentConfig   Json?
  // attachments (plain ids — resolved in queries, no FK to keep this additive)
  productId       String?
  couponId        String?
  // scheduling
  scheduledFor    DateTime?
  recurrence      String?           // NONE | DAILY | WEEKLY | MONTHLY (future)
  sentAt          DateTime?
  // analytics
  audienceSize    Int               @default(0)
  sentCount       Int               @default(0)
  deliveredCount  Int               @default(0)
  openCount       Int               @default(0)
  clickCount      Int               @default(0)
  conversionCount Int               @default(0)
  revenue         Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  events          CampaignEvent[]

  @@index([status, scheduledFor])
  @@index([createdAt])
}

model CampaignEvent {
  id         String           @id @default(cuid())
  campaignId String
  userId     String?
  type       String           // DELIVERED | OPEN | CLICK | CONVERSION
  channel    CampaignChannel?
  meta       Json?
  createdAt  DateTime         @default(now())
  campaign   Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, type])
}

model CampaignTemplate {
  id        String            @id @default(cuid())
  name      String
  category  String            // PROMO | PRODUCT_LAUNCH | WELCOME | WINBACK | COUPON | NEWSLETTER
  channels  CampaignChannel[] @default([IN_APP, EMAIL])
  title     String
  body      String
  imageUrl  String?
  ctaText   String?
  isBuiltIn Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([name])
}

model AudienceSegment {
  id          String      @id @default(cuid())
  name        String      @unique
  type        SegmentType @default(ALL_USERS)
  config      Json?
  cachedCount Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum AutomationTrigger {
  WELCOME
  ABANDONED_CART
  WINBACK
  POST_PURCHASE
}

model AutomationRule {
  id         String            @id @default(cuid())
  name       String
  trigger    AutomationTrigger
  enabled    Boolean           @default(true)
  delayHours Int               @default(24)
  channels   CampaignChannel[] @default([IN_APP, EMAIL])
  title      String
  body       String
  imageUrl   String?
  ctaText    String?
  ctaUrl     String?
  couponId   String?
  sentCount  Int               @default(0)
  lastRunAt  DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  logs       AutomationLog[]

  @@index([trigger, enabled])
}

model AutomationLog {
  id        String              @id @default(cuid())
  ruleId    String
  userId    String
  key       String // dedup key: userId (welcome/winback/cart) or orderId (post-purchase); test:<userId>:<ts> for test sends
  status    AutomationLogStatus @default(SENT)
  channels  CampaignChannel[]   @default([]) // channels that actually delivered
  error     String? // first failure/skip reason (human-readable)
  detail    Json? // per-channel outcome list [{ channel, status, reason? }]
  createdAt DateTime            @default(now())
  rule      AutomationRule      @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, key])
  @@index([ruleId])
  @@index([createdAt])
}

enum AutomationLogStatus {
  SENT // every attempted channel delivered
  PARTIAL // some channels delivered
  FAILED // no channel delivered
  TEST // manual test send (excluded from dedup/stats)
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// One "Consumer Awareness & Healthy Snacking Survey" submission from the public
// /survey page (link-only, bilingual). Answers are stored as typed columns
// (option KEYS from lib/survey.ts, not display labels) so the admin dashboard
// can aggregate counts/percentages cheaply. Contact fields are optional and
// collected only when the respondent opts into updates (Q17).
model SurveyResponse {
  id                  String   @id @default(cuid())
  ageGroup            String
  gender              String
  occupation          String
  occupationOther     String?
  city                String?
  snackFrequency      String
  snacks              String[] @default([])
  snacksOther         String?
  snackPriority       String
  makhanaEaten        String
  makhanaAware        String
  makhanaForms        String[] @default([])
  makhanaBarriers     String[] @default([])
  makhanaBarrierOther String?
  buyPlaces           String[] @default([])
  packSize            String
  flavours            String[] @default([])
  flavourOther        String?
  learnInterest       String
  topics              String[] @default([])
  wantsUpdates        String
  contactName         String?
  contactMobile       String?
  contactEmail        String?
  createdAt           DateTime @default(now())

  @@index([createdAt])
}
