// Result of the "Discover Your Nutriyet Health Score" quiz. Taken anonymously
// (keyed by anonId), then claimed to a user account on signup (userId set,
// claimedAt stamped) to unlock the full report + welcome coupon.
model HealthQuizResult {
  id              String    @id @default(cuid())
  userId          String?
  anonId          String? // nut_anon cookie id, for pre-signup ownership + claim
  score           Int // 0-100
  band            String // e.g. "Thriving" | "Balanced" | "Getting Started"
  answers         Json // { goal, age, exercise, snack, spice, water }
  recommendations Json // { summary, tips[], focus[] } — AI or rule-based
  couponCode      String?
  claimedAt       DateTime?
  createdAt       DateTime  @default(now())
  user            User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([anonId])
  @@index([createdAt])
}

model AISetting {
  id                      String   @id @default("singleton")
  model                   String   @default("llama-3.3-70b-versatile")
  isEnabled               Boolean  @default(true)
  assistantEnabled        Boolean  @default(true)
  searchEnabled           Boolean  @default(true)
  productAssistantEnabled Boolean  @default(true)
  systemPrompt            String?
  temperature             Float    @default(0.7)
  maxTokens               Int      @default(1024)
  totalRequests           Int      @default(0)
  totalTokens             Int      @default(0)
  updatedAt               DateTime @updatedAt
}

