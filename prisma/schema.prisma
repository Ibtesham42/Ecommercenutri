  favicon                         String?
  logo                            String?
  logoDark                        String?
  mapsEmbedUrl                    String?
  metaDescription                 String?
  metaTitle                       String?
  ogImage                         String?
  primaryColor                    String?
  secondaryColor                  String?
  siteName                        String?
  tagline                         String?
  whatsapp                        String?
  logoHeight                      Int?
  logoHeightMobile                Int?
  logoMaxWidth                    Int?
  defaultGstRate                  Int            @default(0)
  defaultShippingFee              Int            @default(4900)
  freeShippingThreshold           Int            @default(49900)
  gstin                           String?
  codFee                          Int?
