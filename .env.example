# =============================================================================
# Nutriyet — Environment Variables
# Copy this file to `.env` and fill in values. Every integration below has a
# graceful keyless fallback, so the app runs end-to-end even with blanks.
# =============================================================================

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Nutriyet"

# --- Database (Neon PostgreSQL) ----------------------------------------------
# Create a free project at https://neon.tech and paste the connection string.
# DATABASE_URL = pooled connection (used by the app at runtime).
# DIRECT_URL   = non-pooled connection (used by Prisma Migrate). For Neon it is
#                the same URL with "-pooler" removed from the host.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# --- Auth (NextAuth v5 / Auth.js) --------------------------------------------
# Generate a secret with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""
# Back-compat alias used by some libraries; set to the same value as AUTH_SECRET.
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com -> Credentials -> OAuth client)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Email -------------------------------------------------------------------
# Provider chain: custom SMTP (preferred) -> Resend -> console stub. With none
# configured, verification/reset links are logged to the server console.
EMAIL_FROM="Nutriyet <noreply@nutriyet.in>"
# Custom SMTP (set these to send via your own mail server / provider):
SMTP_HOST=""
SMTP_PORT="587"            # 465 = implicit TLS, 587/2525 = STARTTLS
SMTP_SECURE="false"        # "true" only for port 465
SMTP_USER=""
SMTP_PASS=""
# Resend (used only when SMTP is not configured) — https://resend.com
RESEND_API_KEY=""

# --- Payments (Razorpay) -----------------------------------------------------
# https://dashboard.razorpay.com -> Settings -> API Keys (use Test mode keys).
# Without keys, checkout uses a mock-success flow for local development.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# --- Media (Cloudinary) ------------------------------------------------------
# https://cloudinary.com -> Dashboard. Without keys, admin image upload falls
# back to storing local/remote URLs directly.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_UPLOAD_PRESET="nutriyet"

# --- AI (Groq) ---------------------------------------------------------------
# https://console.groq.com/keys . Without a key, AI features show a friendly
# "AI not configured" state.
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# --- Cache / Rate limiting (Upstash Redis) -----------------------------------
# https://upstash.com -> Redis -> REST API. Without these, caching and rate
# limiting become no-ops (the app still works, just uncached/unthrottled).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Analytics (optional, privacy-friendly) ----------------------------------
# Plausible/Umami-compatible. Leave blank to disable (no script is injected).
# Example (Plausible): SRC=https://plausible.io/js/script.js  DOMAIN=nutriyet.in
NEXT_PUBLIC_ANALYTICS_SRC=""
NEXT_PUBLIC_ANALYTICS_DOMAIN=""

# --- Admin bootstrap (used by the seed script) -------------------------------
ADMIN_EMAIL="admin@nutriyet.in"
ADMIN_PASSWORD="ChangeMe123!"

# Marketing Hub — secret guarding the scheduled-campaign cron (/api/cron/marketing).
# Vercel Cron sends "Authorization: Bearer $CRON_SECRET". Leave blank locally.
CRON_SECRET=
